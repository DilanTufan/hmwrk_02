<mvc:View controllerName="com.dilan.hmwrk02.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    <Page id="page" title="{i18n>title}" class="sapUiContentPadding">
        <f:SimpleForm editable="true"
                      layout="ResponsiveGridLayout"
                      labelSpanL="4" labelSpanM="4"
                      columnsL="2"   columnsM="2"
                      emptySpanL="2" emptySpanM="1">
         <f:toolbar>
            <Toolbar>
                <Title text="İzin Formu" />
                <ToolbarSpacer />
                <Button type="Emphasized" press="onSave" icon="sap-icon://save" />
            </Toolbar>
         </f:toolbar>             
         <f:content>
              <core:Title text="Kişisel Bilgiler" />
              
              <Label text="Ad/Soyad" required="true"/>
              <Input value="{ path:'formModel>/formData/Ad' ,
                              type:'sap.ui.model.type.String',
                              constraints: { minLength: 1 } ,
                              formatOptions: { parseDefaultValue: true }}" 
                    valueLiveUpdate="true"
                    valueStateText="{i18n>msgValidationError}"
                    placeholder="Adınız"/>
              <Input value="{ path:'formModel>/formData/Soyad' ,
                              type:'sap.ui.model.type.String',
                              constraints: { minLength: 1 } }"
                     valueLiveUpdate="true"
                     valueStateText="{i18n>msgValidationError}"
                     placeholder="Soyadınız"/>

              <Label text="Telefon" required="true"/>
              <Input value="{ path:'formModel>/formData/Telefon' ,
                              type:'sap.ui.model.type.String',
                              constraints: { minLength: 1 } }"
                     valueLiveUpdate="true"
                     placeholder="Telefon"/>

              <Label text="Gidilecek Yer (Ülke / Şehir)" required="true"/>
              <Input value="{formModel>/formData/GidecegiYer/Ulke}" placeholder="Ülke"/>
              <Input value="{formModel>/formData/GidecegiYer/Sehir}" placeholder="Şehir"/>

              <Label text="Adres" required="true"/>
              <TextArea value="{formModel>/formData/Adres}" rows="2" />

              <core:Title text="İzin Detayları" />

              <Label text="İzin Türü" />
              <Select 
                id="idIzinTuru"
                selectedKey="{formModel>/formData/IzinTuruKey}"
                items="{path: 'formModel>/IzinTurleri'}">
                <core:Item key="{formModel>key}" text="{formModel>text}" />
              </Select>

              <Label text="Ehliyetiniz Var mı?" />
              <Switch state="{formModel>/formData/EhliyetVarMi}" />

              <Label text="Ehliyet Durumu" visible="{= ${formModel>/formData/EhliyetVarMi} === true }" />
              <Select visible="{= ${formModel>/formData/EhliyetVarMi} === true }"
                      items="{path: 'formModel>/EhliyetTipleri'}" 
                      selectedKey="{formModel>/formData/EhliyetDurumu}"
                      id="idEhliyetSelect">
                 <core:Item key="{formModel>key}" text="{formModel>text}" />
              </Select>
         </f:content>
        </f:SimpleForm>

        <Table items="{formModel>/PersonelIzinListesi}"
               mode="SingleSelectLeft" 
               selectionChange="onTableSelectionChange"
               noDataText="Henüz bir izin kaydı eklenmedi."
               id="tblIzin">
            <headerToolbar>
                <OverflowToolbar>
                    <Title text="İzinler" level="H3" />
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <Column>
                    <Text text="Personel" />
                </Column>
                <Column minScreenWidth="Tablet" demandPopin="true">
                    <Text text="Telefon" />
                </Column>
                <Column minScreenWidth="Tablet" demandPopin="true">
                    <Text text="İzin Türü" />
                </Column>
                <Column hAlign="End">
                    <Text text="Ehliyet" />
                </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{formModel>Ad} {formModel>Soyad}" />
                        <Text text="{formModel>Telefon}" />
                        <Text text="{formModel>IzinTuruMetni}" />
                        
                        <ObjectStatus 
                            text="{formModel>EhliyetDurumuMetni}"
                            state="{= ${formModel>EhliyetVarMi} ? 'Success' : 'Error' }" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <OverflowToolbar>
            <ToolbarSpacer /> 
            <Button type="Reject" press="onDelete" icon="sap-icon://delete" />
        </OverflowToolbar>
        
    </Page>
</mvc:View>

